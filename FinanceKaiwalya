<!DOCTYPE html>
<html>

<head>
<title>Transaction Entry</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
</head>

<body>

<h2>Transaction Entry</h2>

<form id="transactionForm">

<label>Date</label><br>
<input type="date" id="date" required><br><br>

<label>Transaction Type</label><br>
<select id="transactionType" required>

<option value="">Select</option>
<option value="Income">Income</option>
<option value="Expense">Expense</option>
<option value="Self Transfer">Self Transfer</option>
<option value="Receivable">Receivable (Money Lent)</option>
<option value="Payable">Payable (Money Owed)</option>
<option value="EMI Payment">EMI Payment</option>
<option value="Credit Card Payment">Credit Card Payment</option>

</select>

<br><br>

<button type="submit">Submit</button>

</form>

<script>

const scriptURL = "https://script.google.com/macros/s/AKfycbywPW8hrfem5Xq8InNK9aN_8BZzbty5FOkJpTnkbP0zZ6EReTWYPQSxZHffjiSEEPFE/exec";

document.getElementById("transactionForm").addEventListener("submit", function(e){

e.preventDefault();

navigator.geolocation.getCurrentPosition(function(position){

const latitude = position.coords.latitude;
const longitude = position.coords.longitude;

const data = {

date: document.getElementById("date").value,
time: new Date().toLocaleTimeString(),
location: latitude + "," + longitude,
latitude: latitude,
longitude: longitude,
transactionType: document.getElementById("transactionType").value

};

fetch(scriptURL, {

method: "POST",
body: JSON.stringify(data)

})
.then(response => response.json())
.then(data => {

alert("Transaction Saved Successfully");

document.getElementById("transactionForm").reset();

});

});

});

</script>

</body>

</html>
